# pulse-frontend environment variables
#
# NEXT_PUBLIC_* values are inlined into the client JavaScript bundle by
# `next build`. They MUST be set at build time:
#   - In CI: via `build-args:` in .github/workflows/build-and-push.yml
#   - In local dev: via `.env.local` (copy this file to .env.local first)
#
# Prod vs staging differences are set in the CI workflow's `target` step,
# keyed on github.ref (main → prod, staging → staging-app).
#
# Values prefixed with NEXT_PUBLIC_ end up in the browser and are NOT secret.
# Mollie profile ID looks secret-ish but isn't — it's the public identifier
# for the Mollie checkout profile and appears in every checkout API call.
#
# scripts/validate-env.mjs enforces that required vars are set at build time
# and fails the build loudly if not — no more silent localhost fallbacks
# shipping to production.

# -------- REQUIRED at build time (all client-side, all baked into bundle) --------

# pulse-backend API base URL.
# Prod:    https://pulse-api.ciphera.net
# Staging: https://pulse-api-staging.ciphera.net
# Dev:     http://localhost:8082
NEXT_PUBLIC_API_URL=https://pulse-api.ciphera.net

# id-frontend public URL (used for OAuth redirects from pulse → id).
# Prod + Staging: https://id.ciphera.net
# Dev:            http://localhost:3001
NEXT_PUBLIC_AUTH_URL=https://id.ciphera.net

# pulse-frontend's own public URL (used for self-links like /faq, OAuth
# callback redirect_uri, and the SiteVisibilityTab share link builder).
# Prod:    https://pulse.ciphera.net
# Staging: https://pulse-staging.ciphera.net
# Dev:     http://localhost:3003
NEXT_PUBLIC_APP_URL=https://pulse.ciphera.net

# id-backend API base URL (used by token refresh and server actions).
# Prod + Staging: https://api.id.ciphera.net
# Dev:            http://localhost:8081
NEXT_PUBLIC_AUTH_API_URL=https://api.id.ciphera.net

# Captcha service base URL (includes /api/v1 suffix).
# Prod + Staging: https://captcha.ciphera.net/api/v1
# Dev:            http://localhost:8083/api/v1
NEXT_PUBLIC_CAPTCHA_API_URL=https://captcha.ciphera.net/api/v1

# Mollie profile ID (public billing profile reference, looks like `pfl_XXXXX`).
# Prod + Staging use the same profile; live vs test is controlled by testmode.
NEXT_PUBLIC_MOLLIE_PROFILE_ID=pfl_3WTMG2peXk

# Mollie testmode flag. String "true" in staging (hits Mollie test API),
# string "false" in prod (hits Mollie live API). Must match the backend's
# Mollie API key type (test_XXX vs live_XXX).
# Prod:    false
# Staging: true
NEXT_PUBLIC_MOLLIE_TESTMODE=false
